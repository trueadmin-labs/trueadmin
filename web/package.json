{
  "name": "@trueadmin/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "vite --mode development --host 0.0.0.0",
    "dev:test": "vite --mode test --host 0.0.0.0",
    "build": "tsc -b && vite build --mode production",
    "build:test": "tsc -b && vite build --mode test",
    "preview": "vite preview --host 0.0.0.0",
    "module:validate": "node scripts/validate-modules.mjs",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -b --pretty false",
    "check": "pnpm module:validate && pnpm lint && pnpm typecheck && pnpm test:run && pnpm build",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/icons": "6.2.2",
    "@ant-design/pro-components": "3.1.12-0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "5.100.9",
    "@trueadmin/web-antd": "^0.1.1",
    "@trueadmin/web-core": "^0.1.9",
    "@trueadmin/web-react": "^0.1.0",
    "alova": "3.5.1",
    "antd": "6.3.7",
    "antd-style": "4.1.0",
    "dayjs": "1.11.20",
    "motion": "12.38.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "react-router": "7.15.0",
    "remark-gfm": "^4.0.1",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.1.1",
    "msw": "2.14.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}

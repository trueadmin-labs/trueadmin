{
  "name": "trueadmin-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "trueadmin": "trueadmin",
    "doctor": "trueadmin doctor",
    "plugin:list": "trueadmin plugin list",
    "plugin:install": "trueadmin plugin install",
    "plugin:sync": "trueadmin plugin sync",
    "plugin:validate": "trueadmin plugin validate",
    "web:module:validate": "pnpm --dir web module:validate",
    "backend:analyse": "composer analyse --working-dir=backend",
    "backend:test": "composer test --working-dir=backend",
    "web:check": "pnpm --dir web check",
    "check": "npm run doctor && npm run plugin:validate && npm run web:check && npm run backend:analyse && npm run backend:test"
  },
  "devDependencies": {
    "@trueadmin/cli": "^0.1.13"
  }
}
